# yamllint configuration for container-images
extends: default

ignore: |
  .venv/
  venv/
  .worktrees/

rules:
  line-length:
    max: 120
    level: warning
    allow-non-breakable-words: true
    allow-non-breakable-inline-mappings: true

  # Allow unquoted true/false for GitHub Actions boolean inputs
  truthy:
    allowed-values: ['true', 'false']
    check-keys: false

  # Disallow duplicate keys
  key-duplicates: enable

  indentation:
    spaces: 2
    indent-sequences: true

  comments:
    require-starting-space: true
    min-spaces-from-content: 1

  comments-indentation: {}

  # Catalog YAML files and workflow files don't use document-start marker
  document-start: disable
